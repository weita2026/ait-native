{
  "schema_version": 1,
  "suite_id": "stable_smoke",
  "display_name": "Stable Smoke",
  "plane": "patchset",
  "default_blocking": true,
  "mode": "gate",
  "purpose": "Run the stable transport/runtime/web smoke slice for shared patchsets.",
  "runner": {
    "kind": "pytest",
    "args": [
      "tests/test_native_smoke.py",
      "tests/test_native_server_runtime.py",
      "-q"
    ]
  },
  "artifacts": {
    "junit_xml": ".ait/generated/ci/stable_smoke.junit.xml",
    "log_path": ".ait/generated/ci/stable_smoke.log"
  }
}
