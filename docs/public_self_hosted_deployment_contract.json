{
  "schema_version": 1,
  "revision_date": "2026-05-26",
  "guide_path": "docs/SELF_HOSTED_TEAM_DEPLOYMENT.md",
  "audiences": [
    "external_operator",
    "self_hosted_team_operator",
    "external_agent"
  ],
  "deployment_mode": "self_hosted_team",
  "topology": {
    "required_services": [
      "postgres",
      "ait-server",
      "ait-worker"
    ],
    "optional_services": [
      "ait-agent"
    ]
  },
  "licensing": {
    "control_plane": "AGPL-3.0-only OR LicenseRef-AIT-Commercial",
    "local_trust_layer": "Apache-2.0 for ait and ait-agent"
  },
  "bootstrap_steps": [
    {
      "id": "runtime_root",
      "command": "mkdir -p /srv/ait/server-data /srv/ait/retire-exports && export AIT_NATIVE_SERVER_DATA=/srv/ait/server-data && export AIT_SERVER_RETIRE_EXPORT_ROOT=/srv/ait/retire-exports"
    },
    {
      "id": "runtime_backend",
      "command": "export AIT_NATIVE_SERVER_DB_BACKEND=postgres"
    },
    {
      "id": "postgres_dsn",
      "command": "export AIT_NATIVE_SERVER_POSTGRES_DSN='postgresql://<user>:<password>@<host>:5432/ait_native'"
    },
    {
      "id": "core_up",
      "commands": [
        "pg_isready -d \"$AIT_NATIVE_SERVER_POSTGRES_DSN\"",
        "AIT_NATIVE_SERVER_DATA=\"$AIT_NATIVE_SERVER_DATA\" AIT_SERVER_RETIRE_EXPORT_ROOT=\"$AIT_SERVER_RETIRE_EXPORT_ROOT\" AIT_NATIVE_SERVER_DB_BACKEND=postgres AIT_NATIVE_SERVER_POSTGRES_DSN=\"$AIT_NATIVE_SERVER_POSTGRES_DSN\" AIT_NATIVE_SERVER_POSTGRES_CONTENT_SCHEMA=\"${AIT_NATIVE_SERVER_POSTGRES_CONTENT_SCHEMA:-ait_native_content}\" AIT_NATIVE_SERVER_POSTGRES_CONTROL_SCHEMA=\"${AIT_NATIVE_SERVER_POSTGRES_CONTROL_SCHEMA:-ait_native_control}\" AIT_NATIVE_SERVER_HOST=\"${AIT_NATIVE_SERVER_HOST:-127.0.0.1}\" AIT_NATIVE_SERVER_PORT=\"${AIT_NATIVE_SERVER_PORT:-8088}\" ait-server",
        "AIT_NATIVE_SERVER_DATA=\"$AIT_NATIVE_SERVER_DATA\" AIT_SERVER_RETIRE_EXPORT_ROOT=\"$AIT_SERVER_RETIRE_EXPORT_ROOT\" AIT_NATIVE_SERVER_DB_BACKEND=postgres AIT_NATIVE_SERVER_POSTGRES_DSN=\"$AIT_NATIVE_SERVER_POSTGRES_DSN\" AIT_NATIVE_SERVER_POSTGRES_CONTENT_SCHEMA=\"${AIT_NATIVE_SERVER_POSTGRES_CONTENT_SCHEMA:-ait_native_content}\" AIT_NATIVE_SERVER_POSTGRES_CONTROL_SCHEMA=\"${AIT_NATIVE_SERVER_POSTGRES_CONTROL_SCHEMA:-ait_native_control}\" ait-worker run --worker-id worker-1"
      ]
    }
  ],
  "boot_order": [
    "postgres",
    "ait-server",
    "ait-worker",
    "external runtime workers (optional)"
  ],
  "readiness_commands": [
    "curl -fsS http://<ait-server-host>:<port>/healthz",
    "ait doctor runtime-root --server-data \"$AIT_NATIVE_SERVER_DATA\" --json",
    "test -d \"$AIT_SERVER_RETIRE_EXPORT_ROOT\" && test -w \"$AIT_SERVER_RETIRE_EXPORT_ROOT\"",
    "ait doctor postgres --server-data \"$AIT_NATIVE_SERVER_DATA\" --dsn \"$AIT_NATIVE_SERVER_POSTGRES_DSN\" --content-schema \"${AIT_NATIVE_SERVER_POSTGRES_CONTENT_SCHEMA:-ait_native_content}\" --control-schema \"${AIT_NATIVE_SERVER_POSTGRES_CONTROL_SCHEMA:-ait_native_control}\" --connect --json",
    "ait repo readiness --json",
    "ait repo jobs --diagnostics --json"
  ],
  "backup_and_recovery": {
    "must_backup": [
      "postgres content/control schemas",
      "server runtime root",
      "retire export root"
    ],
    "daily_helper": "python3 scripts/runtime_backup.py --runtime-root \"$AIT_NATIVE_SERVER_DATA\" --output-dir /srv/ait-backups --keep 8",
    "related_docs": [
      "docs/server_backup_restore_dr.md",
      "docs/server_disaster_recovery_checklist.md"
    ]
  },
  "decision_boundary": [
    {
      "when": "single developer and first md-to-land loop",
      "guide": "docs/LOCAL_QUICKSTART.md"
    },
    {
      "when": "shared review, policy, or worker-backed execution is required",
      "guide": "docs/SELF_HOSTED_TEAM_DEPLOYMENT.md"
    }
  ]
}
